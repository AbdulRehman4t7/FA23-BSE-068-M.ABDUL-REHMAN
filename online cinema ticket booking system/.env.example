# JazzCash sandbox / backend (do not commit real production secrets)
JAZZCASH_MERCHANT_ID=
JAZZCASH_MERCHANT_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# Optional override (defaults to sandbox DoMWalletTransaction v2.0)
# JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/2.0/Purchase/DoMWalletTransaction

# Production / static hosting: browser calls this URL instead of the Vite dev proxy.
# Example after deploying supabase/functions/jazzcash-mwallet:
# VITE_JAZZCASH_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1/jazzcash-mwallet
